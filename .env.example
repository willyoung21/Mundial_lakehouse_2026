# ── APIs externas ──────────────────────────────────────────────────────────────
# worldcup26.ir — registro gratuito en https://worldcup26.ir/api-docs
# JWT válido 84 días, se renueva automáticamente en cada ejecución.
WORLDCUP26_EMAIL=tu@email.com
WORLDCUP26_PASSWORD=tu_password_worldcup26

# API-Football (comentado — free plan no incluye season 2026)
# API_FOOTBALL_KEY=tu_key_de_rapidapi_aqui
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ── MinIO (Bronze layer — Parquet local) ──────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=football-lakehouse

# ── Data Warehouse — Neon.tech (Silver + Gold layers) ─────────────────────────
# 1. Regístrate gratis en https://neon.tech (sin tarjeta de crédito)
# 2. Crea un proyecto "football-lakehouse"
# 3. Copia los valores desde Dashboard → Connect → Connection details
POSTGRES_HOST=ep-xxx-xxx.us-east-2.aws.neon.tech
POSTGRES_PORT=5432
POSTGRES_USER=football_owner
POSTGRES_PASSWORD=tu_password_neon
POSTGRES_DB=football_dw

# ── Airflow ────────────────────────────────────────────────────────────────────
# Generar Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=TU_FERNET_KEY_AQUI
# Generar Secret key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=TU_SECRET_KEY_AQUI

# ── FastAPI ────────────────────────────────────────────────────────────────────
API_PORT=8000
MODEL_PATH=/app/models/model_winner_predictor.pkl
